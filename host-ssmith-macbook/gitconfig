[push]
	default = simple
[user]
	email = ssmith@missiondata.com
	name = Sean Smith
[merge]
	tool = vimdiff
[core]
	filemode = true
	editor = /usr/local/bin/vim
	excludesfile = /Users/ssmith/.gitignore_global
	ignorecase = false
[filter "media"]
	clean = git media clean %f
	smudge = git media smudge %f
	required = true
[filter "lfs"]
	clean = git-lfs clean %f
	smudge = git-lfs smudge %f
	required = true
[alias]
	graph = !git --no-pager log --all -n 15 --graph --abbrev-commit --decorate --format=tformat:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an <%ce>%C(reset)'
	stop-tracking = !git update-index --assume-unchanged
	start-tracking = !git update-index --no-assume-unchanged
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
[credential]
	helper = osxkeychain
[help]
	autocorrect = 1
